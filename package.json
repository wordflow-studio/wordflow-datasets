{
  "bin": {
    "wordflow-dataset": "dist/cli.mjs"
  },
  "bugs": {
    "url": "https://github.com/wordflow-studio/wordflow-datasets/issues"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "description": "Repeatable dataset generation and seeding for WordPress sites.",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/cli": "^2.29.8",
    "@intellectronica/ruler": "^0.3.34",
    "@types/bun": "^1.3.9",
    "@wp-playground/cli": "^3.1.12",
    "marked": "^17.0.4",
    "pkg-pr-new": "^0.0.62",
    "publint": "^0.3.16",
    "tsdown": "^0.20.3"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/wordflow-studio/wordflow-datasets#readme",
  "keywords": [
    "cli",
    "dataset",
    "seeding",
    "wordpress"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "name": "wordflow-dataset",
  "packageManager": "bun@^1.3.0",
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wordflow-studio/wordflow-datasets.git"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "check-types": "tsc -b --noEmit",
    "ci": "bun run build && bun run lint && bun run check-types && bun test",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --error-on-warnings --write",
    "release": "changeset publish",
    "ruler:apply": "ruler apply --local-only",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "version": "changeset version && bun lint:fix",
    "wp:smoke:editorial-sample": "bun run ./scripts/wordpress-apply-smoke.ts datasets/editorial-sample",
    "wp:smoke:theme-unit-test": "bun run ./scripts/wordpress-apply-smoke.ts datasets/theme-unit-test"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "0.0.0"
}
